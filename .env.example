# LiveKit (required for voice + web)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Agent dispatch — must match AGENT_NAME in frontend/.env.local
AGENT_NAME=code-voice-agent

# Cursor SDK (required for inspect_code / fix_issue tools)
# Get a key: https://cursor.com/dashboard/integrations
CURSOR_API_KEY=cursor_your_key_here
# Code tools model: default (Auto), composer-2.5, gpt-5.5, etc.
CURSOR_MODEL=default
CURSOR_RUNTIME=local
CURSOR_DEFAULT_CWD=
# Comma-separated directories; workspace paths must live under one of these roots
CURSOR_ALLOWED_ROOTS=

# Optional: direct model keys if not using LiveKit Inference
# OPENAI_API_KEY=
# DEEPGRAM_API_KEY=
# CARTESIA_API_KEY=
